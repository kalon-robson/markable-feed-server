{
  "name": "graphql-server-boilerplate",
  "version": "0.0.0",
  "description": "This GraphQL server boilerplate provides a basic structure for building servers.",
  "repository": "git@github.com:innovixx/graphql-server-boilerplate.git",
  "author": "Innovixx <support@innovixx.co.uk>",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "pnpm generate:openapi && pnpm tsc && pnpm copyfiles",
    "serve": "node ./dist/index.js",
    "cleanDev": "pnpm db:reset && tsx ./src/seed/index.ts && pnpm dev",
    "db:migrate:main": "npx prisma migrate dev && npx prisma generate",
    "db:migrate:main:prod": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset --force",
    "generate:openapi": "npx tsx src/bin/generateOpenApi/index.ts",
    "copyfiles": "copyfiles -u 1 \"src/**/*.json\" \"src/**/.graphql\" \"src/**/*.png\" dist/",
    "lint": "eslint ./src/**/*.{js,jsx,ts,tsx,graphql}",
    "lint-staged": "lint-staged --verbose",
    "prepare": "if [ -d node_modules/husky ]; then husky; fi"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.9",
    "@graphql-tools/schema": "^9.0.17",
    "@graphql-tools/utils": "^8.12.0",
    "@innovixx/prisma-gql-generator": "^0.0.7",
    "@parcel/watcher": "^2.5.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.0",
    "graphql-parse-resolve-info": "^4.14.1",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.1.0",
    "lodash.merge": "^4.6.2",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@innovixx/eslint-config": "^3.0.12",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/serve-static": "2.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "copyfiles": "^2.4.1",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.4.5",
    "typescript-json-schema": "^0.67.2"
  },
  "lint-staged": {
    "**/*.graphql": "eslint",
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --quiet",
      "bash -c tsc"
    ]
  }
}